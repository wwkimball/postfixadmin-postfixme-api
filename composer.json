{
    "name": "kimball/pfme-api",
    "description": "PostfixMe API - Mobile-friendly REST API for PostfixAdmin alias management",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Pfme\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pfme\\Api\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src --level=8",
        "phpcs": "phpcs src --standard=PSR12"
    }
}
